[node name="RichTextLabel" type="RichTextLabel" parent="MarginContainer/VBoxContainer/TabContainer/历史记录/MarginContainer/VBoxContainer"]
layout_mode = 2
bbcode_enabled = true
text = "Alpha会记录每一次对话的内容，只需要在左上角点击历史记录，即可查看对话的记录。

点击历史记录可以恢复这次对话，并继续对话。

点击删除按钮可以删除这条对话记录。无法撤销。

历史记录保存在项目配置下，如果需要查询，可以点击godot的项目>打开\"用户数据\"文件夹

在打开的文件夹中可以找到.alpha文件夹，其中history.json文件就是历史记录。"
fit_content = true

